<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Babli · SEO Intelligence Operating System</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/chartjs-plugin-datalabels/2.2.0/chartjs-plugin-datalabels.min.js"></script>
<style>
/* ============================================================
   DESIGN SYSTEM · Helvetica · #093C76 on #FFFFF0
   Executive-reporting visual style
   ============================================================ */
:root{
  /* surface */
  --bg:#FFFFF0;
  --surface:#FFFFFF;
  --surface-2:#FAF7E4;
  --surface-3:#F3EFD7;

  /* navy primary */
  --navy:#093C76;
  --navy-2:#1659AD;
  --navy-3:#4A7BC4;
  --navy-soft:rgba(9,60,118,.06);
  --navy-soft-2:rgba(9,60,118,.12);

  /* accent gold */
  --gold:#B8801A;
  --gold-soft:rgba(184,128,26,.10);

  /* status */
  --pos:#1F7A4D;
  --pos-soft:rgba(31,122,77,.10);
  --neg:#B3261E;
  --neg-soft:rgba(179,38,30,.10);
  --warn:#B8801A;
  --warn-soft:rgba(184,128,26,.10);
  --info:#1659AD;
  --info-soft:rgba(22,89,173,.10);

  /* text */
  --ink-1:#0E1A2B;
  --ink-2:#3D4A63;
  --ink-3:#6B7691;
  --ink-4:#95A0B8;

  /* lines */
  --line:#E9E3CB;
  --line-2:#D9D0B2;
  --rule:#EFE9D2;

  /* spacing & form */
  --r-sm:8px;
  --r-md:10px;
  --r-lg:14px;
  --r-xl:18px;

  /* shadows — soft executive */
  --sh-1:0 1px 2px rgba(9,60,118,.04);
  --sh-2:0 1px 3px rgba(9,60,118,.05), 0 6px 18px rgba(9,60,118,.06);
  --sh-3:0 2px 6px rgba(9,60,118,.06), 0 16px 40px rgba(9,60,118,.08);
}
*{box-sizing:border-box}
html,body{margin:0;padding:0;background:var(--bg);color:var(--ink-1);
  font-family:Helvetica,'Helvetica Neue',Arial,sans-serif;-webkit-font-smoothing:antialiased;
  font-feature-settings:'kern' 1;}
a{color:inherit;text-decoration:none}
::selection{background:rgba(9,60,118,.18)}

/* ============================================================
   APP LAYOUT — fixed left sidebar only
   ============================================================ */
.app{display:grid;grid-template-columns:248px 1fr;min-height:100vh}
.sidebar{
  position:sticky;top:0;height:100vh;
  background:var(--surface);
  border-right:1px solid var(--line);
  padding:24px 18px;display:flex;flex-direction:column;gap:4px;overflow-y:auto;
  box-shadow:var(--sh-1);
}
.brand{display:flex;align-items:center;gap:12px;padding:4px 6px 20px;margin-bottom:6px;border-bottom:1px solid var(--line)}
.brand-mark{width:46px;height:46px;border-radius:var(--r-md);background:#FFFFFF;border:1px solid var(--line);
  display:grid;place-items:center;padding:4px;overflow:hidden}
.brand-mark img{width:100%;height:100%;object-fit:contain}
.brand-text{display:flex;flex-direction:column;line-height:1.2}
.brand-text b{font-size:14px;color:var(--navy);font-weight:700;letter-spacing:.01em}
.brand-text span{font-size:10.5px;color:var(--ink-3);letter-spacing:.08em;text-transform:uppercase;margin-top:2px}

.nav-section{font-size:10px;text-transform:uppercase;letter-spacing:.14em;color:var(--ink-4);padding:18px 10px 6px;font-weight:700}
.nav-item{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:var(--r-sm);
  cursor:pointer;color:var(--ink-2);font-size:13px;font-weight:500;transition:.15s;
  border-left:2px solid transparent;}
.nav-item:hover{background:var(--surface-2);color:var(--navy)}
.nav-item.active{background:var(--navy-soft);color:var(--navy);font-weight:700;border-left-color:var(--navy)}
.nav-num{font-size:10.5px;color:var(--ink-4);width:18px;font-variant-numeric:tabular-nums}
.nav-item.active .nav-num{color:var(--navy)}

.sidebar-foot{margin-top:auto;padding:14px 8px 4px;border-top:1px solid var(--line);display:flex;flex-direction:column;gap:10px;font-size:10.5px;color:var(--ink-3);line-height:1.45}
.source-strip{display:flex;align-items:flex-start;gap:8px}
.source-strip .dot{margin-top:5px}
.dot{width:7px;height:7px;border-radius:50%;background:var(--pos);box-shadow:0 0 0 3px rgba(31,122,77,.18);flex-shrink:0}
.gh-strip{display:flex;align-items:center;justify-content:center;padding:14px 16px;background:var(--navy);border-radius:var(--r-sm);border:1px solid var(--navy);box-shadow:var(--sh-1)}
.gh-strip img{height:36px;width:auto;max-width:100%;object-fit:contain;display:block}

/* ============================================================
   MAIN AREA
   ============================================================ */
.main{padding:28px 36px 64px;max-width:1640px;margin:0 auto;width:100%}

/* topbar — metadata only, NO navigation */
.topbar{display:flex;align-items:center;gap:14px;margin-bottom:24px;flex-wrap:wrap}
.crumbs{font-size:12px;color:var(--ink-3)}
.crumbs b{color:var(--ink-1);font-weight:700}
.spacer{flex:1}
.meta-pill{display:inline-flex;align-items:center;gap:8px;padding:7px 14px;border-radius:var(--r-sm);
  background:var(--surface);border:1px solid var(--line);font-size:12px;color:var(--ink-2);box-shadow:var(--sh-1)}
.meta-pill b{color:var(--navy);font-weight:600}
.meta-pill.solid{background:var(--navy);color:#FFFFF0;border-color:var(--navy)}
.meta-pill.solid b{color:#FFFFF0}

/* ============================================================
   HERO — navy banner like reference
   ============================================================ */
.hero{
  background:linear-gradient(135deg, #093C76 0%, #0e4a8c 60%, #1659AD 100%);
  color:#FFFFF0; border-radius:var(--r-xl); padding:34px 36px;
  margin-bottom:28px; box-shadow:var(--sh-3); position:relative; overflow:hidden;
}
.hero::after{content:'';position:absolute;right:-80px;top:-80px;width:340px;height:340px;
  background:radial-gradient(circle, rgba(255,255,240,.08), transparent 60%);}
.hero .ek{font-size:11px;letter-spacing:.18em;color:#B9D3F2;text-transform:uppercase;margin-bottom:10px;font-weight:700}
.hero h1{font-size:30px;margin:0 0 12px;letter-spacing:-.02em;font-weight:700;line-height:1.15;max-width:75ch}
.hero p.lede{margin:0;color:rgba(255,255,240,.85);font-size:14px;line-height:1.6;max-width:78ch}
.hero .lede b{color:#FFFFF0;font-weight:600}
.hero-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:32px;margin-top:24px;padding-top:24px;border-top:1px solid rgba(255,255,240,.18)}
.hero-stats .stat{}
.hero-stats .stat .l{font-size:10.5px;color:#B9D3F2;letter-spacing:.1em;text-transform:uppercase;margin-bottom:6px}
.hero-stats .stat .v{font-size:26px;font-weight:700;letter-spacing:-.01em}
.hero-stats .stat .s{font-size:11.5px;color:#9FB8DA;margin-top:2px}

/* ============================================================
   SECTION
   ============================================================ */
.section{margin-top:36px;scroll-margin-top:20px}
.section-head{margin-bottom:18px}
.section-head .eyebrow{font-size:10.5px;letter-spacing:.16em;color:var(--gold);text-transform:uppercase;font-weight:700;margin-bottom:6px}
.section-head h2{font-size:22px;margin:0;color:var(--navy);font-weight:700;letter-spacing:-.01em}
.section-head p{margin:6px 0 0;color:var(--ink-3);font-size:13px;max-width:78ch;line-height:1.55}

.section-tools{display:flex;align-items:center;gap:10px;margin-top:14px;flex-wrap:wrap}

/* ============================================================
   KPI GRID
   ============================================================ */
.kpi-grid{display:grid;grid-template-columns:repeat(6,minmax(0,1fr));gap:14px}
.kpi-grid.c5{grid-template-columns:repeat(5,1fr)}
.kpi-grid.c4{grid-template-columns:repeat(4,1fr)}
.kpi-grid.c3{grid-template-columns:repeat(3,1fr)}
@media (max-width:1280px){.kpi-grid,.kpi-grid.c5,.kpi-grid.c4,.kpi-grid.c3{grid-template-columns:repeat(3,1fr)}}
@media (max-width:780px){.kpi-grid,.kpi-grid.c5,.kpi-grid.c4,.kpi-grid.c3{grid-template-columns:repeat(2,1fr)}}

.kpi{background:var(--surface);border:1px solid var(--line);border-radius:var(--r-md);
  padding:16px 18px;box-shadow:var(--sh-1);min-height:108px;display:flex;flex-direction:column;justify-content:space-between}
.kpi .lbl{font-size:11px;color:var(--ink-3);letter-spacing:.06em;text-transform:uppercase;font-weight:600;display:flex;justify-content:space-between;align-items:center}
.kpi .val{font-size:24px;font-weight:700;margin-top:8px;letter-spacing:-.01em;color:var(--ink-1);line-height:1.1}
.kpi .sub{display:flex;align-items:center;gap:8px;margin-top:8px;font-size:11.5px;color:var(--ink-3)}
.kpi .sub b{color:var(--ink-1);font-weight:600}

.delta{display:inline-flex;align-items:center;gap:3px;padding:2px 7px;border-radius:5px;
  font-size:11px;font-weight:700;font-variant-numeric:tabular-nums}
.delta.up{background:var(--pos-soft);color:var(--pos)}
.delta.down{background:var(--neg-soft);color:var(--neg)}
.delta.flat{background:var(--surface-3);color:var(--ink-3)}

/* ============================================================
   CARDS / GRIDS
   ============================================================ */
.grid{display:grid;gap:18px}
.g-2{grid-template-columns:1fr 1fr}
.g-3{grid-template-columns:repeat(3,1fr)}
.g-4{grid-template-columns:repeat(4,1fr)}
.g-2-1{grid-template-columns:2fr 1fr}
.g-1-2{grid-template-columns:1fr 2fr}
@media (max-width:1100px){.g-2,.g-3,.g-4,.g-2-1,.g-1-2{grid-template-columns:1fr}}

.card{background:var(--surface);border:1px solid var(--line);border-radius:var(--r-lg);
  padding:22px;box-shadow:var(--sh-1)}
.card.tinted{background:var(--surface-2)}
.card-head{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px;gap:14px}
.card-head h3{margin:0;font-size:14px;font-weight:700;color:var(--navy);letter-spacing:.01em}
.card-head p{margin:4px 0 0;font-size:12px;color:var(--ink-3);line-height:1.45}
.card-head .right{display:flex;gap:6px;flex-shrink:0}

/* chips */
.chip{display:inline-flex;align-items:center;font-size:11px;padding:3px 9px;border-radius:6px;
  border:1px solid var(--line-2);color:var(--ink-2);background:var(--surface-2);font-weight:600}
.chip.pos{color:var(--pos);border-color:rgba(31,122,77,.3);background:var(--pos-soft)}
.chip.neg{color:var(--neg);border-color:rgba(179,38,30,.3);background:var(--neg-soft)}
.chip.warn{color:var(--warn);border-color:rgba(184,128,26,.3);background:var(--warn-soft)}
.chip.info{color:var(--info);border-color:rgba(22,89,173,.3);background:var(--info-soft)}
.chip.navy{color:#FFFFF0;background:var(--navy);border-color:var(--navy)}

/* severity */
.sev{display:inline-flex;align-items:center;gap:5px;font-size:10.5px;font-weight:700;padding:3px 8px;border-radius:5px;letter-spacing:.04em}
.sev.crit{background:var(--neg-soft);color:var(--neg)}
.sev.high{background:var(--warn-soft);color:var(--warn)}
.sev.med{background:var(--info-soft);color:var(--info)}
.sev.low{background:var(--pos-soft);color:var(--pos)}

/* ============================================================
   TABLES
   ============================================================ */
.table{width:100%;border-collapse:collapse;font-size:12.5px}
.table th{text-align:left;font-weight:700;color:var(--ink-3);font-size:10.5px;
  text-transform:uppercase;letter-spacing:.08em;padding:10px 12px;border-bottom:1px solid var(--line)}
.table td{padding:11px 12px;border-bottom:1px solid var(--rule);color:var(--ink-1);vertical-align:middle}
.table tr:last-child td{border-bottom:none}
.table tr:hover td{background:var(--surface-2)}
.table .num{text-align:right;font-variant-numeric:tabular-nums}
.table .truncate{max-width:290px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.table .sub{font-size:11px;color:var(--ink-3);margin-top:2px;font-weight:400}

.mini-bar{position:relative;height:6px;border-radius:3px;background:var(--surface-3);overflow:hidden;min-width:60px}
.mini-bar > i{position:absolute;left:0;top:0;bottom:0;border-radius:3px;background:var(--navy);display:block}

/* scrollable table container — shows ~10 rows, scrolls to reveal rest. Sticky header. */
.scroll-table{max-height:520px;overflow-y:auto;border:1px solid var(--line);border-radius:var(--r-sm);background:var(--surface)}
.scroll-table.sm{max-height:480px}
.scroll-table.lg{max-height:640px}
.scroll-table table{border-collapse:separate;border-spacing:0}
.scroll-table .table th{position:sticky;top:0;background:var(--surface-2);z-index:2;box-shadow:0 1px 0 var(--line)}
.scroll-table .table td{background:var(--surface)}
.scroll-table::-webkit-scrollbar{width:8px}
.scroll-table::-webkit-scrollbar-track{background:var(--surface-2);border-radius:4px}
.scroll-table::-webkit-scrollbar-thumb{background:var(--line-2);border-radius:4px}
.scroll-table::-webkit-scrollbar-thumb:hover{background:var(--ink-4)}
.scroll-hint{font-size:11px;color:var(--ink-3);font-style:italic;margin-top:8px;text-align:right}

/* empty-state for not-connected sources */
.empty-state{display:flex;flex-direction:column;align-items:center;justify-content:center;padding:36px 24px;text-align:center;gap:10px;min-height:180px}
.empty-state .es-icon{width:44px;height:44px;border-radius:12px;background:var(--surface-3);color:var(--ink-3);display:grid;place-items:center;font-size:20px;font-weight:700}
.empty-state .es-title{font-size:14px;font-weight:700;color:var(--ink-2);margin:0}
.empty-state .es-msg{font-size:12.5px;color:var(--ink-3);max-width:42ch;line-height:1.55;margin:0}
.empty-state .es-cta{font-size:11px;color:var(--ink-4);letter-spacing:.08em;text-transform:uppercase;font-weight:600;margin-top:4px}

/* ============================================================
   CHARTS
   ============================================================ */
.chart-wrap{position:relative;height:260px;padding:6px 0}
.chart-wrap.sm{height:190px}
.chart-wrap.tall{height:340px}
.chart-wrap.xl{height:380px}

/* ============================================================
   INSIGHT BANNER (executive callout)
   ============================================================ */
.callout{background:var(--surface);border:1px solid var(--line);border-left:4px solid var(--navy);
  border-radius:var(--r-md);padding:18px 22px;box-shadow:var(--sh-1);display:flex;gap:16px;align-items:flex-start}
.callout.gold{border-left-color:var(--gold)}
.callout.warn{border-left-color:var(--warn);background:linear-gradient(90deg, var(--warn-soft) 0%, var(--surface) 30%)}
.callout.neg{border-left-color:var(--neg);background:linear-gradient(90deg, var(--neg-soft) 0%, var(--surface) 30%)}
.callout.pos{border-left-color:var(--pos);background:linear-gradient(90deg, var(--pos-soft) 0%, var(--surface) 30%)}
.callout-mark{font-size:12px;font-weight:700;letter-spacing:.12em;color:var(--navy);
  text-transform:uppercase;width:90px;flex-shrink:0;padding-top:1px}
.callout.gold .callout-mark{color:var(--gold)}
.callout.warn .callout-mark{color:var(--warn)}
.callout.neg .callout-mark{color:var(--neg)}
.callout.pos .callout-mark{color:var(--pos)}
.callout-body{flex:1}
.callout-body strong{display:block;font-size:14.5px;color:var(--ink-1);margin-bottom:6px;font-weight:700}
.callout-body p{margin:0;font-size:13.5px;line-height:1.65;color:var(--ink-2)}
.callout-body b{color:var(--ink-1);font-weight:700}

/* ============================================================
   TABS (within-section, e.g. Blog/Guides/Lookbooks) — functional
   ============================================================ */
.tabs{display:inline-flex;background:var(--surface-2);border:1px solid var(--line);border-radius:var(--r-sm);padding:3px;gap:2px}
.tabs button{background:transparent;border:none;color:var(--ink-3);padding:7px 14px;border-radius:6px;
  font-size:12px;cursor:pointer;font-weight:600;font-family:inherit;transition:.15s}
.tabs button:hover{color:var(--navy)}
.tabs button.on{background:var(--surface);color:var(--navy);box-shadow:var(--sh-1)}

.tab-panel{display:none}
.tab-panel.on{display:block;animation:fadeIn .25s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(4px)}to{opacity:1;transform:none}}

/* ============================================================
   MISC
   ============================================================ */
.divider{height:1px;background:var(--line);margin:36px 0 0}

.matrix{position:relative;height:340px;border:1px solid var(--line);border-radius:var(--r-md);background:
  linear-gradient(to right, transparent 49.6%, var(--line) 49.6% 50.4%, transparent 50.4%),
  linear-gradient(to bottom, transparent 49.6%, var(--line) 49.6% 50.4%, transparent 50.4%),
  var(--surface);}
.matrix .lbl{position:absolute;font-size:10.5px;color:var(--ink-3);text-transform:uppercase;letter-spacing:.1em;font-weight:700}
.matrix .q-tl{top:10px;left:14px;color:var(--pos)}
.matrix .q-tr{top:10px;right:14px;color:var(--gold)}
.matrix .q-bl{bottom:10px;left:14px;color:var(--ink-4)}
.matrix .q-br{bottom:10px;right:14px;color:var(--neg)}
.matrix .pt{position:absolute;width:11px;height:11px;border-radius:50%;background:var(--navy);
  box-shadow:0 0 0 4px rgba(9,60,118,.16);transform:translate(-50%,-50%);cursor:pointer}
.matrix .pt span{position:absolute;left:16px;top:-7px;font-size:11px;white-space:nowrap;
  color:var(--ink-1);background:var(--surface);padding:3px 8px;border-radius:5px;border:1px solid var(--line);
  box-shadow:var(--sh-1);font-weight:600}

.anomaly{display:flex;gap:12px;padding:14px 16px;border-radius:var(--r-md);
  background:var(--surface);border:1px solid var(--line);margin-bottom:10px;
  font-size:13px;color:var(--ink-2);align-items:flex-start;box-shadow:var(--sh-1);line-height:1.55}
.anomaly .icn{width:24px;height:24px;border-radius:6px;display:grid;place-items:center;flex-shrink:0;
  font-size:12px;font-weight:700}
.anomaly.pos .icn{background:var(--pos-soft);color:var(--pos)}
.anomaly.neg .icn{background:var(--neg-soft);color:var(--neg)}
.anomaly.warn .icn{background:var(--warn-soft);color:var(--warn)}
.anomaly.info .icn{background:var(--info-soft);color:var(--info)}
.anomaly b{color:var(--ink-1);font-weight:700}

/* task list */
.task{display:grid;grid-template-columns:auto 1fr auto;gap:18px;padding:16px 18px;
  border-radius:var(--r-md);background:var(--surface);border:1px solid var(--line);
  margin-bottom:10px;box-shadow:var(--sh-1);align-items:center}
.task .sq{width:38px;height:38px;border-radius:var(--r-sm);background:var(--navy);color:#FFFFF0;
  display:grid;place-items:center;font-weight:700;font-size:13px;letter-spacing:.02em}
.task .sq.alt{background:var(--gold)}
.task .sq.q{background:var(--pos)}
.task .meta{display:flex;gap:18px;color:var(--ink-3);font-size:11.5px;margin-top:6px;flex-wrap:wrap}
.task .meta b{color:var(--ink-1);font-weight:600}
.task .impact{display:flex;flex-direction:column;align-items:flex-end;gap:6px;min-width:130px}
.task .score{font-weight:700;font-size:22px;line-height:1;color:var(--navy)}
.task .title{font-weight:700;color:var(--ink-1);font-size:13.5px}

/* heatmap */
.heat{display:grid;grid-template-columns:repeat(7,1fr);gap:5px}
.heat .cell{aspect-ratio:1.5/1;border-radius:4px;background:var(--navy-soft);display:grid;place-items:center;font-size:10px;color:var(--ink-3);font-weight:700}

/* footer */
.foot{margin-top:60px;padding:24px 0 0;border-top:1px solid var(--line);
  color:var(--ink-3);font-size:11.5px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:10px;line-height:1.5}

/* responsive */
@media (max-width:1100px){
  .app{grid-template-columns:1fr}
  .sidebar{position:relative;height:auto;width:100%;flex-direction:row;flex-wrap:wrap;border-right:none;border-bottom:1px solid var(--line)}
  .brand{width:100%;border-bottom:none;padding-bottom:8px;margin-bottom:0}
  .nav-section{display:none}
  .nav-item{padding:6px 10px;font-size:12px;border-left:none}
  .nav-item.active{border-left:none;border-bottom:2px solid var(--navy)}
  .hero{padding:24px;border-radius:var(--r-md)}
  .hero h1{font-size:22px}
  .hero-stats{grid-template-columns:repeat(2,1fr);gap:16px}
}
</style>
</head>
<body>

<div class="app">

<!-- =========================================================
     SIDEBAR — ONLY NAVIGATION
     ========================================================= -->
<aside class="sidebar">
  <div class="brand">
    <div class="brand-mark"><img src="https://babli.in/cdn/shop/files/logo.png?v=1701265077&amp;width=220" alt="Babli"></div>
    <div class="brand-text">
      <b>Babli · Intel OS</b>
      <span>SEO Executive Report</span>
    </div>
  </div>

  <div class="nav-section">Intelligence Layers</div>
  <a class="nav-item active" href="#executive"><span class="nav-num">01</span> Executive Summary</a>
  <a class="nav-item" href="#health"><span class="nav-num">02</span> SEO Health Center</a>
  <a class="nav-item" href="#growth"><span class="nav-num">03</span> Organic Growth</a>
